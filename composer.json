{
    "name": "codesaur/http-application",
    "description": "PSR-7 & PSR-15 нийцсэн хөнгөн, уян хатан HTTP Application цөм",
    "keywords": [
        "http", "application", "http application", "router", "server request handler", "psr-7", "psr-15", "mongol", "mongolia", "монгол", "codesaur", "narankhuu", "coden", "кодзавр", "наранхүү", "коден"
    ],
    "homepage": "https://github.com/codesaur-php",
    "authors": [
        {
            "name": "Narankhuu (+976 99000287)",
            "email": "codesaur@gmail.com",
            "homepage": "https://github.com/codesaur"
        }
    ],
    "require": {
        "psr/http-server-middleware": "^1.0.2",
        "codesaur/router": "^5.0.0",
        "codesaur/http-message": "^3.0.0"
    },
    "autoload": {
        "psr-4": {
            "codesaur\\Http\\Application\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "codesaur\\Http\\Application\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html coverage/html --coverage-text",
        "test:coverage-clover": "phpunit --coverage-clover coverage.xml",
        "test:integration": "phpunit --testsuite \"Integration Tests\"",
        "test:unit": "phpunit --testsuite \"HTTP Application Test Suite\" --exclude-group integration"
    },
    "license": "MIT",
    "minimum-stability": "dev"
}
